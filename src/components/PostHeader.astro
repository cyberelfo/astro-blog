---
import { slugify, formatDate } from "../lib/utils";
import VideoEmbed from "./VideoEmbed.astro";

const { title, description, date, category, author, image, youtube, vimeo } =
    Astro.props;

const hasVideo = youtube || vimeo;
---

<header>
    <div class="container">
        <small>
            <a href={`/category/${slugify(category)}/`} class="badge"
                >{category}</a
            >
        </small>
        <h1 class="h2">{title}</h1>
        <p>
            por <a href={`/author/${slugify(author)}/`}>{author}</a> • {
                formatDate(date)
            }
        </p>
    </div>
    {
        hasVideo ? (
            <VideoEmbed {youtube} {vimeo} />
        ) : (
            image && image.src && (
                <img
                    src={image.src}
                    alt={image.alt || ""}
                    class="hero-image"
                    loading="eager"
                    decoding="async"
                    width="1200"
                    height="675"
                />
            )
        )
    }
</header>
