<dialog id="search-modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Busca</h2>
            <button id="close-search-btn" aria-label="Fechar busca" class="close-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="modal-body">
            <div id="search-container"></div>
        </div>
    </div>
</dialog>

<script is:inline>
    let pagefindLoaded = false;
    let pagefindUI = null;

    window.loadPagefind = function(callback) {
        if (pagefindLoaded) {
            if (callback) callback();
            return;
        }

        // Inject CSS
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = '/pagefind/pagefind-ui.css';
        document.head.appendChild(link);

        // Inject JS
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind-ui.js';
        script.onload = () => {
            pagefindLoaded = true;
            if (callback) callback();
        };
        document.head.appendChild(script);
    };

    window.initPagefind = function() {
        if (typeof PagefindUI !== 'undefined' && !pagefindUI) {
            pagefindUI = new PagefindUI({
                element: "#search-container",
                showSubresults: true,
                showImages: true,
                translations: {
                    placeholder: "Pesquisar por posts...",
                    clear_search: "Limpar",
                    load_more: "Carregar mais resultados",
                    search_label: "Buscar",
                    filters_label: "Filtros",
                    zero_results: "Nenhum resultado encontrado para '[SEARCH_TERM]'",
                    many_results: "[COUNT] resultados encontrados para '[SEARCH_TERM]'",
                    one_result: "[COUNT] resultado encontrado para '[SEARCH_TERM]'",
                    alt_search: "Nenhum resultado para '[SEARCH_TERM]'. Mostrando resultados para '[ALT_TERM]' no lugar.",
                    search_suggestion: "Nenhum resultado para '[SEARCH_TERM]'. Tente um dos seguintes termos:",
                    searching: "Buscando por '[SEARCH_TERM]'..."
                }
            });

            // Make result thumbnails clickable: Pagefind renders result-thumb as a
            // plain <div>; we wrap it in an <a> to the same URL as the result title.
            const container = document.getElementById('search-container');
            if (container) {
                const observer = new MutationObserver(() => {
                    container.querySelectorAll('.pagefind-ui__result-thumb:not([data-linked])').forEach((thumb) => {
                        const result = thumb.closest('.pagefind-ui__result');
                        if (!result) return;
                        const link = result.querySelector('.pagefind-ui__result-link');
                        if (!link) return;

                        const anchor = document.createElement('a');
                        anchor.href = link.href;
                        anchor.tabIndex = -1; // title link is the accessible target
                        anchor.setAttribute('aria-hidden', 'true');
                        anchor.style.display = 'contents'; // no layout impact
                        thumb.parentNode.insertBefore(anchor, thumb);
                        anchor.appendChild(thumb);
                        thumb.setAttribute('data-linked', ''); // mark as processed
                    });
                });
                observer.observe(container, { childList: true, subtree: true });
            }
        }
    };

    // Setup close behaviors
    const dialog = document.getElementById("search-modal");
    const closeBtn = document.getElementById("close-search-btn");

    function closeDialog() {
        dialog.classList.add("fade-out");
        dialog.addEventListener("animationend", function handler() {
            dialog.classList.remove("fade-out");
            dialog.close();
            dialog.removeEventListener("animationend", handler);
        }, { once: true });
    }

    if (closeBtn && dialog) {
        closeBtn.addEventListener("click", closeDialog);

        // Close when clicking on the backdrop (outside the main content box)
        dialog.addEventListener("click", (e) => {
            const rect = dialog.getBoundingClientRect();
            const isInDialog = (
                e.clientX >= rect.left &&
                e.clientX <= rect.right &&
                e.clientY >= rect.top &&
                e.clientY <= rect.bottom
            );
            if (!isInDialog) {
                closeDialog();
            }
        });

        // Close on Escape key press with transition
        dialog.addEventListener("cancel", (e) => {
            e.preventDefault(); // Prevent instant close
            closeDialog();
        });
    }
</script>

<style>
    #search-modal {
        background: hsla(var(--muted) / 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid hsla(var(--txt) / 0.08);
        border-radius: var(--radius-md);
        padding: var(--space-md);
        width: 90%;
        max-width: 650px;
        height: min(80dvh, 600px);
        box-shadow: var(--shadow-lg);
        color: hsl(var(--txt));
        
        /* Reset center placement */
        position: fixed;
        inset: 0;
        margin: auto;
        overflow: hidden;
    }

    .modal-content {
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-block-end: var(--space-sm);
        padding-block-end: var(--space-xs);
        border-bottom: 1px solid hsla(var(--txt) / 0.08);
    }

    .modal-header h2 {
        font-family: 'Karla', sans-serif;
        font-size: var(--fs-lg);
        font-weight: 700;
        margin: 0;
    }

    .close-btn {
        background: transparent;
        box-shadow: none;
        border: none;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-full);
        color: hsl(var(--txt));
        transition: background-color var(--transition-ease-fast), color var(--transition-ease-fast);
    }

    .close-btn:hover {
        background-color: hsla(var(--txt) / 0.08);
        color: hsl(var(--accent));
    }

    .modal-body {
        flex: 1;
        overflow-y: auto;
        padding-inline-end: var(--space-2xs);
        
        /* Custom scrollbar to keep layout elegant */
        &::-webkit-scrollbar {
            width: 6px;
        }
        &::-webkit-scrollbar-track {
            background: transparent;
        }
        &::-webkit-scrollbar-thumb {
            background: hsla(var(--txt) / 0.15);
            border-radius: var(--radius-full);
        }
        &::-webkit-scrollbar-thumb:hover {
            background: hsla(var(--txt) / 0.3);
        }
    }

    /* Animations for Open & Close state */
    dialog[open] {
        animation: modal-fade-in 0.3s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
    }

    dialog[open]::backdrop {
        animation: backdrop-fade-in 0.3s ease forwards;
    }

    dialog.fade-out {
        animation: modal-fade-out 0.25s ease forwards !important;
    }

    dialog.fade-out::backdrop {
        animation: backdrop-fade-out 0.25s ease forwards !important;
    }

    @keyframes modal-fade-in {
        from {
            opacity: 0;
            transform: scale(0.95) translateY(10px);
        }
        to {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
    }

    @keyframes backdrop-fade-in {
        from {
            background: transparent;
            backdrop-filter: blur(0px);
        }
        to {
            background: hsla(var(--bkg) / 0.7);
            backdrop-filter: blur(12px);
        }
    }

    @keyframes modal-fade-out {
        from {
            opacity: 1;
            transform: scale(1) translateY(0);
        }
        to {
            opacity: 0;
            transform: scale(0.95) translateY(10px);
        }
    }

    @keyframes backdrop-fade-out {
        from {
            background: hsla(var(--bkg) / 0.7);
            backdrop-filter: blur(12px);
        }
        to {
            background: transparent;
            backdrop-filter: blur(0px);
        }
    }

    /* Pagefind Theme Overrides */
    #search-modal {
        --pagefind-ui-primary: hsl(var(--accent));
        --pagefind-ui-text: hsl(var(--txt));
        --pagefind-ui-background: hsl(var(--muted));
        --pagefind-ui-border: hsla(var(--txt) / 0.12);
        --pagefind-ui-font: 'Karla', sans-serif;
        --pagefind-ui-border-radius: var(--radius-sm);
    }

    /* Scoped global styles for dynamically generated Pagefind elements */
    #search-container {
        padding-block-start: var(--space-2xs);
    }

    :global(.pagefind-ui__search-clear) {
        width: auto !important;
        height: auto !important;
        padding: 4px 8px !important;
    }

    :global(.pagefind-ui__search-input) {
        font-family: 'Karla', sans-serif !important;
        background-color: hsla(var(--bkg) / 0.8) !important;
        border: 1px solid hsla(var(--txt) / 0.15) !important;
        font-weight: 400 !important;
        transition: border-color var(--transition-ease-fast), box-shadow var(--transition-ease-fast) !important;
    }

    :global(.pagefind-ui__search-input:focus) {
        outline: none !important;
        border-color: hsl(var(--accent)) !important;
        box-shadow: 0 0 0 3px hsla(var(--accent) / 0.25) !important;
    }

    :global(.pagefind-ui__result-link) {
        font-family: 'Libre Baskerville', Georgia, serif !important;
        font-weight: 700 !important;
        color: hsl(var(--txt)) !important;
        transition: color var(--transition-ease-fast) !important;
    }

    :global(.pagefind-ui__result-link:hover) {
        color: hsl(var(--accent)) !important;
        text-decoration: none !important;
    }

    :global(.pagefind-ui__result-excerpt) {
        font-family: 'Karla', sans-serif !important;
        color: hsla(var(--txt) / 0.8) !important;
        font-size: var(--fs-sm) !important;
        line-height: 1.5 !important;
    }

    :global(.pagefind-ui__result-excerpt mark) {
        background-color: hsla(var(--accent) / 0.2) !important;
        color: hsl(var(--txt)) !important;
        font-weight: bold !important;
        padding-inline: 2px !important;
        border-radius: 2px !important;
    }

    /* Clickable thumbnail — added by MutationObserver */
    :global(.pagefind-ui__result-thumb) {
        cursor: pointer;
        transition: opacity var(--transition-ease-fast);
    }

    :global(.pagefind-ui__result-thumb:hover) {
        opacity: 0.85;
    }

    :global(.pagefind-ui__button) {
        font-family: 'Karla', sans-serif !important;
        background-color: hsla(var(--txt) / 0.05) !important;
        border: 1px solid hsla(var(--txt) / 0.1) !important;
        color: hsl(var(--txt)) !important;
        width: auto !important;
        height: auto !important;
        padding: var(--space-xs) var(--space-md) !important;
        font-weight: bold !important;
        transition: background-color var(--transition-ease-fast), border-color var(--transition-ease-fast) !important;
    }

    :global(.pagefind-ui__button:hover) {
        background-color: hsla(var(--txt) / 0.1) !important;
        border-color: hsla(var(--txt) / 0.2) !important;
    }
</style>
