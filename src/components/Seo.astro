---
import siteData from "../data/siteData.json";
import jsonLDGenerator from "../lib/jsonLD";

const {
    title,
    description,
    url = Astro.url,
    image,
    frontmatter,
    robots,
} = Astro.props;

const jsonLD = jsonLDGenerator({
    type: frontmatter ? "post" : "website",
    post: frontmatter,
    url,
});

const siteUrl = Astro.site || "https://www.cafeetv.com.br";
const relativeImageSrc = image?.src || siteData.image.src;
const absoluteImageUrl = new URL(relativeImageSrc, siteUrl).toString();

// Derive content type from extension; fall back to image/jpeg
const ext = relativeImageSrc.split(".").pop()?.toLowerCase();
const imageType =
    ext === "png" ? "image/png"
    : ext === "webp" ? "image/webp"
    : ext === "gif" ? "image/gif"
    : "image/jpeg";
---

<!-- SEO -->
<link rel="canonical" href={url} />

<!-- Open Graph -->
<meta property="og:site_name" content={siteData.title} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={url} />
<meta property="og:image" content={absoluteImageUrl} />
<meta property="og:image:type" content={imageType} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="600" />
<meta property="og:image:alt" content={image?.alt || siteData.image.alt} />

<!-- Twitter -->
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={absoluteImageUrl} />
<meta name="twitter:image:alt" content={title} />
<meta name="twitter:domain" content={import.meta.env.SITE} />

{robots && <meta name="robots" content="noindex, nofollow" />}

<!-- JSON LD -->
<Fragment set:html={jsonLD} />
