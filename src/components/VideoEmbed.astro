---
import { YouTube, Vimeo } from "astro-embed";

interface Props {
    youtube?: string;
    vimeo?: string;
}

const { youtube, vimeo } = Astro.props;
---

<div class="video-embed-container" data-youtube={youtube} data-vimeo={vimeo}>
    {
        youtube && (
            <YouTube
                id={youtube}
                class="responsive-video"
                posterQuality="maxresdefault"
            />
        )
    }
    {
        vimeo && (
            <Vimeo
                id={vimeo}
                class="responsive-video"
                params="color=f0603f&title=0&byline=0"
            />
        )
    }
</div>

<script>
    // Fetch the real aspect ratio from the video provider's oEmbed API
    // and apply it to the container so the embed is not letterboxed.
    const container = document.querySelector<HTMLElement>(".video-embed-container");
    if (container) {
        const vimeoId = container.getAttribute("data-vimeo");
        const youtubeId = container.getAttribute("data-youtube");

        if (vimeoId) {
            fetch(`https://vimeo.com/api/oembed.json?url=https://vimeo.com/${vimeoId}`)
                .then((res) => res.json())
                .then((data) => {
                    if (data.width && data.height) {
                        container.style.aspectRatio = `${data.width} / ${data.height}`;
                        container.style.height = "auto";
                    }
                })
                .catch((err) => console.error("Error fetching Vimeo ratio:", err));
        } else if (youtubeId) {
            fetch(`https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=${youtubeId}`)
                .then((res) => res.json())
                .then((data) => {
                    if (data.width && data.height) {
                        container.style.aspectRatio = `${data.width} / ${data.height}`;
                        container.style.height = "auto";
                    }
                })
                .catch((err) => console.error("Error fetching YouTube ratio:", err));
        }
    }
</script>

<style>
    .video-embed-container {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        border-radius: 4px;
        overflow: hidden;
    }

    .video-embed-container :global(lite-youtube),
    .video-embed-container :global(lite-vimeo),
    .video-embed-container :global(iframe) {
        position: absolute;
        top: 0;
        left: 0;
        width: 100% !important;
        height: 100% !important;
        max-width: 100% !important;
        border: none;
    }

    .video-embed-container :global(lite-vimeo) :global(.ltv-playbtn) {
        width: 100% !important;
        height: 100% !important;
        background: transparent !important;
        box-shadow: none !important;
        border: none !important;
        display: block !important;
    }

    .responsive-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }
</style>
