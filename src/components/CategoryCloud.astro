---
import { getCollection, type CollectionEntry } from "astro:content";
import { formatBlogPosts, slugify } from "../lib/utils";

interface Props {
    showCount?: boolean;
    posts?: CollectionEntry<"blog">[];
}

const { showCount, posts: passedPosts } = Astro.props;

// Use posts passed by the parent when available, avoiding a duplicate getCollection call
const allPosts = passedPosts ?? await getCollection("blog");
const formattedPosts = formatBlogPosts(allPosts);

const allCategories = formattedPosts.map((post) => post.data.category.toLowerCase());

const processedCats = allCategories.reduce<Record<string, number>>((acc, category) => {
    acc[category] = (acc[category] ?? 0) + 1;
    return acc;
}, {});
---

<ul class="categories">
    {
        Object.entries(processedCats).map(([key, val]) => (
            <li>
                <a class="badge" href={`/category/${slugify(key)}/`}>
                    {key} {showCount && `(${val})`}
                </a>
            </li>
        ))
    }
</ul>
