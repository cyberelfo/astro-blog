---
// component imports
import CategoryCloud from "../components/CategoryCloud.astro";
import PostHeader from "../components/PostHeader.astro";
import MainLayout from "./MainLayout.astro";
import RelatedPosts from "../components/RelatedPosts.astro";

// Astro content collections import
import { getCollection, type CollectionEntry } from "astro:content";

// Util imports
import { formatBlogPosts } from "../lib/utils";

const { frontmatter } = Astro.props;
const { title, description, date, category, author, image, youtube, vimeo } =
    frontmatter;

const allPosts = await getCollection("blog");
const formattedPosts = formatBlogPosts(allPosts, { sortByDate: false });

const relatedPosts = formattedPosts
    .filter(
        (post: CollectionEntry<"blog">) =>
            post.data.category.toLowerCase() ===
                category.toLowerCase() && post.data.title !== title,
    )
    .slice(0, 3);
---

<MainLayout
    {title}
    {description}
    image={frontmatter.image}
    {frontmatter}
    robots={frontmatter.robots}
>
    <PostHeader
        {title}
        {description}
        {date}
        {category}
        {author}
        {image}
        {youtube}
        {vimeo}
    />
    <div class="post-content">
        <div class="content">
            <slot />
        </div>
        <div class="sidebar">
            <aside class="container" aria-label="Blog categories">
                <h2 class="h3">Categorias</h2>
                <CategoryCloud />
            </aside>
            {
                relatedPosts.length > 0 && (
                    <aside class="container" aria-label="Related posts">
                        <h2 class="h3">Posts relacionados</h2>
                        <RelatedPosts {relatedPosts} />
                    </aside>
                )
            }
        </div>
    </div>
</MainLayout>
