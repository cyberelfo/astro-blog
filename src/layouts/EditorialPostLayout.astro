---
// component imports
import MainLayout from "./MainLayout.astro";
import { YouTube } from "astro-embed";

// Util imports
import { slugify, formatDate } from "../lib/utils";

const { frontmatter } = Astro.props;
const { title, description, date, category, author, image, youtube, vimeo } = frontmatter;

const hasVideo = youtube || vimeo;
---

<MainLayout
    {title}
    {description}
    image={frontmatter.image}
    {frontmatter}
    robots={frontmatter.robots}
>
    <!-- Add Google Fonts specifically for this layout -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Karla:ital,wght@0,300;0,400;0,700;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

    <article class="editorial-post">
        <!-- Editorial Header -->
        <header class="editorial-header">
            <div class="header-meta">
                <a href={`/category/${slugify(category)}/`} class="editorial-category">{category}</a>
                <span class="meta-divider">•</span>
                <span class="editorial-date">{formatDate(date)}</span>
            </div>
            <h1 class="editorial-title">{title}</h1>
            <div class="editorial-author">
                Escrito por <a href={`/author/${slugify(author)}/`}>{author}</a>
            </div>
        </header>

        <!-- Media Element (Featured Image or Video) -->
        {
            hasVideo ? (
                <div class="editorial-media-wrapper">
                    <div class="editorial-video-container" data-youtube={youtube} data-vimeo={vimeo}>
                        {
                            youtube && (
                                <YouTube
                                    id={youtube}
                                    class="responsive-video"
                                    posterQuality="maxresdefault"
                                />
                            )
                        }
                        {
                            vimeo && (
                                <iframe
                                    class="responsive-video"
                                    src={`https://player.vimeo.com/video/${vimeo}?color=d15b39&title=0&byline=0`}
                                    frameborder="0"
                                    allow="autoplay; fullscreen; picture-in-picture"
                                    allowfullscreen
                                />
                            )
                        }
                    </div>
                </div>
            ) : (
                image && image.src && (
                    <div class="editorial-media-wrapper">
                        <img 
                            src={image.src} 
                            alt={image.alt || ""} 
                            class="editorial-hero-image" 
                            loading="eager" 
                            decoding="async" 
                        />
                    </div>
                )
            )
        }

        <!-- Main Layout with Content (editorial style) -->
        <div class="editorial-body-grid">
            <div class="editorial-content-wrapper">
                <div class="editorial-content">
                    <slot />
                </div>
            </div>
        </div>
    </article>
</MainLayout>

<style>
    /* Scope styles for the Editorial Post */
    .editorial-post {
        font-family: 'Libre Baskerville', Georgia, serif;
        background-color: #fbfbfb; /* off-white clean editorial background */
        color: #222222; /* dark charcoal, high contrast but softer than pure black */
        margin: 0;
        padding-bottom: var(--space-2xl);
        min-height: 100vh;
    }

    /* Reset global colors inside the post for clean light theme */
    :global(body) {
        background-color: #fbfbfb !important;
        color: #222222 !important;
    }

    .editorial-header {
        max-width: 1210px;
        margin: 0 auto;
        padding: var(--space-xl) var(--space-md) var(--space-md);
        text-align: center;
    }

    .header-meta {
        font-family: 'Karla', sans-serif;
        font-size: var(--fs-sm);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: var(--space-xs);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2xs);
        color: #666;
    }

    .editorial-category {
        color: #d15b39; /* Warm editorial accent */
        text-decoration: none;
        font-weight: 700;
    }

    .editorial-category:hover {
        text-decoration: underline;
    }

    .meta-divider {
        color: #ccc;
    }

    .editorial-title {
        font-family: 'Libre Baskerville', Georgia, serif;
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        line-height: 1.25;
        font-weight: 700;
        margin-bottom: var(--space-sm);
        color: #111;
        text-wrap: balance;
    }

    .editorial-author {
        font-family: 'Karla', sans-serif;
        font-size: var(--fs-md);
        color: #555;
    }

    .editorial-author a {
        color: #111;
        text-decoration: underline;
        font-weight: 500;
    }

    .editorial-media-wrapper {
        width: 100%;
        max-width: 1210px;
        margin: 0 auto var(--space-xl);
        padding-inline: var(--space-md);
    }

    .editorial-hero-image {
        width: 100%;
        height: auto;
        max-height: 600px;
        object-fit: cover;
        border-radius: 4px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    .editorial-video-container {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 9;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
        border-radius: 4px;
        overflow: hidden;
    }

    .editorial-video-container :global(lite-youtube),
    .editorial-video-container :global(iframe) {
        position: absolute;
        top: 0;
        left: 0;
        width: 100% !important;
        height: 100% !important;
        max-width: 100% !important;
        border: none;
    }

    .responsive-video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    .editorial-body-grid {
        max-width: 1210px;
        margin: 0 auto;
        padding-inline: var(--space-md);
        display: grid;
        gap: var(--space-xl);
        align-items: start;
    }

    .editorial-content-wrapper {
        width: 100%;
    }

    .editorial-content {
        width: 100%;
        font-size: clamp(16px, 2.2vw, 20px);
        line-height: 2.0; /* Crucial Zippy Frames line height */
        color: #292929;
    }

    /* Stylize article content elements */
    .editorial-content :global(p) {
        max-width: none !important;
        margin-bottom: var(--space-md);
        text-wrap: pretty;
    }

    .editorial-content :global(h2),
    .editorial-content :global(h3),
    .editorial-content :global(h4) {
        font-family: 'Libre Baskerville', Georgia, serif;
        color: #111;
        font-weight: 700;
        margin-top: var(--space-lg);
        margin-bottom: var(--space-xs);
        line-height: 1.3;
    }

    .editorial-content :global(h2) {
        font-size: var(--fs-xl);
    }

    .editorial-content :global(h3) {
        font-size: var(--fs-lg);
    }

    .editorial-content :global(a) {
        color: #d15b39;
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .editorial-content :global(a:hover) {
        color: #111;
    }

    .editorial-content :global(ul),
    .editorial-content :global(ol) {
        margin-bottom: var(--space-md);
        padding-left: var(--space-md);
    }

    .editorial-content :global(li) {
        margin-bottom: var(--space-2xs);
    }

    .editorial-content :global(blockquote) {
        margin: var(--space-lg) 0;
        padding-left: var(--space-md);
        border-left: 4px solid #d15b39;
        font-style: italic;
        color: #555;
    }
</style>

<script>
    // Responsive ratio code
    const container = document.querySelector(".editorial-video-container") as HTMLElement;
    if (container) {
        const vimeoId = container.getAttribute("data-vimeo");
        const youtubeId = container.getAttribute("data-youtube");

        if (vimeoId) {
            const url = `https://vimeo.com/api/oembed.json?url=https://vimeo.com/${vimeoId}`;
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if (data.width && data.height) {
                        container.style.aspectRatio = `${data.width} / ${data.height}`;
                        container.style.height = "auto";
                    }
                })
                .catch(err => console.error("Error fetching Vimeo ratio:", err));
        } else if (youtubeId) {
            const url = `https://www.youtube.com/oembed?url=https://www.youtube.com/watch?v=${youtubeId}`;
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if (data.width && data.height) {
                        container.style.aspectRatio = `${data.width} / ${data.height}`;
                        container.style.height = "auto";
                    }
                })
                .catch(err => console.error("Error fetching YouTube ratio:", err));
        }
    }
</script>
