---
// component imports
import MainLayout from "./MainLayout.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import CreditsBox from "../components/CreditsBox.astro";

// Util imports
import { slugify, formatDate } from "../lib/utils";

const { frontmatter } = Astro.props;
const { title, description, date, category, author, image, youtube, vimeo } = frontmatter;

const hasVideo = youtube || vimeo;
---

<MainLayout
    {title}
    {description}
    image={frontmatter.image}
    {frontmatter}
    robots={frontmatter.robots}
>
    <article class="editorial-post">
        {/* Explicit image hint for Pagefind search results.
            Pagefind reads the first <img> in data-pagefind-body for its thumbnail.
            Posts with a video hero render an <iframe>, not an <img>, so without this
            hint those results appear with no image in the search modal. */}
        {image?.src && (
            <meta data-pagefind-meta="image[content]" content={image.src} />
        )}
        <!-- Editorial Header -->
        <header class="editorial-header">
            <div class="header-meta">
                <a href={`/category/${slugify(category)}/`} class="editorial-category">{category}</a>
                <span class="meta-divider">•</span>
                <span class="editorial-date">{formatDate(date)}</span>
            </div>
            <h1 class="editorial-title">{title}</h1>
            <div class="editorial-author">
                Escrito por <a href={`/author/${slugify(author)}/`}>{author}</a>
            </div>
        </header>

        <!-- Media Element (Featured Image or Video) -->
        {
            hasVideo ? (
                <div class="editorial-media-wrapper">
                    <VideoEmbed {youtube} {vimeo} />
                </div>
            ) : (
                image && image.src && (
                    <div class="editorial-media-wrapper">
                        <img
                            src={image.src}
                            alt={image.alt || ""}
                            class="editorial-hero-image"
                            loading="eager"
                            decoding="async"
                        />
                    </div>
                )
            )
        }

        <!-- Main Layout with Content (editorial style) -->
        <div class="editorial-body-grid">
            <div class="editorial-content-wrapper">
                <div class="editorial-content">
                    <slot />
                    <CreditsBox {...frontmatter} />
                </div>
            </div>
        </div>
    </article>
</MainLayout>

<style>
    /* Scope styles for the Editorial Post */
    .editorial-post {
        font-family: 'Libre Baskerville', Georgia, serif;
        color: hsl(var(--txt));
        margin: 0;
        padding-bottom: var(--space-2xl);
        min-height: 100vh;
    }

    .editorial-header {
        max-width: 1210px;
        margin: 0 auto;
        padding: var(--space-xl) var(--space-md) var(--space-md);
        text-align: center;
    }

    .header-meta {
        font-family: 'Karla', sans-serif;
        font-size: var(--fs-sm);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: var(--space-xs);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-2xs);
        color: hsla(var(--txt) / 0.55);
    }

    .editorial-category {
        color: hsl(var(--accent));
        text-decoration: none;
        font-weight: 700;
    }

    .editorial-category:hover {
        text-decoration: underline;
    }

    .meta-divider {
        color: hsla(var(--txt) / 0.25);
    }

    .editorial-title {
        font-family: 'Libre Baskerville', Georgia, serif;
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        line-height: 1.25;
        font-weight: 700;
        margin-bottom: var(--space-sm);
        color: hsl(var(--txt));
        text-wrap: balance;
    }

    .editorial-author {
        font-family: 'Karla', sans-serif;
        font-size: var(--fs-md);
        color: hsla(var(--txt) / 0.7);
    }

    .editorial-author a {
        color: hsl(var(--txt));
        text-decoration: underline;
        font-weight: 500;
    }

    .editorial-media-wrapper {
        width: 100%;
        max-width: 1210px;
        margin: 0 auto var(--space-xl);
        padding-inline: var(--space-md);
    }

    .editorial-hero-image {
        width: 100%;
        height: auto;
        max-height: 600px;
        object-fit: cover;
        border-radius: 4px;
        box-shadow: var(--shadow-md);
    }

    .editorial-body-grid {
        max-width: 1210px;
        margin: 0 auto;
        padding-inline: var(--space-md);
        display: grid;
        gap: var(--space-xl);
        align-items: start;
    }

    .editorial-content-wrapper {
        width: 100%;
    }

    .editorial-content {
        width: 100%;
        font-size: clamp(16px, 2.2vw, 20px);
        line-height: 2.0; /* Crucial Zippy Frames line height */
        color: hsl(var(--txt));
    }

    /* Stylize article content elements */
    .editorial-content :global(p) {
        max-width: none !important;
        margin-bottom: var(--space-md);
        text-wrap: pretty;
    }

    .editorial-content :global(h2),
    .editorial-content :global(h3),
    .editorial-content :global(h4) {
        font-family: 'Libre Baskerville', Georgia, serif;
        color: hsl(var(--txt));
        font-weight: 700;
        margin-top: var(--space-lg);
        margin-bottom: var(--space-xs);
        line-height: 1.3;
    }

    .editorial-content :global(h2) {
        font-size: var(--fs-xl);
    }

    .editorial-content :global(h3) {
        font-size: var(--fs-lg);
    }

    .editorial-content :global(a) {
        color: hsl(var(--accent));
        text-decoration: underline;
        text-underline-offset: 4px;
    }

    .editorial-content :global(a:hover) {
        color: hsl(var(--txt));
    }

    .editorial-content :global(ul),
    .editorial-content :global(ol) {
        margin-bottom: var(--space-md);
        padding-left: var(--space-md);
    }

    .editorial-content :global(li) {
        margin-bottom: var(--space-2xs);
    }

    .editorial-content :global(blockquote) {
        margin: var(--space-lg) 0;
        padding-left: var(--space-md);
        border-left: 4px solid hsl(var(--accent));
        font-style: italic;
        color: hsla(var(--txt) / 0.7);
    }
</style>
