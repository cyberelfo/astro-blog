---
import MainLayout from "../../layouts/MainLayout.astro";

// Component Imports
import PostCard from "../../components/PostCard.astro";

// Astro content collections import
import { getCollection } from "astro:content";

import { slugify, formatBlogPosts } from "../../lib/utils";

export async function getStaticPaths() {
    const allPosts = await getCollection("blog");
    const formattedPosts = formatBlogPosts(allPosts);
    const allCategories = [
        ...new Set(
            formattedPosts.map((post: CollectionEntry<"blog">) => post.data.category).flat(),
        ),
    ];
    return allCategories.map((category: string) => {
        const catPosts = formattedPosts.filter(
            (post: CollectionEntry<"blog">) => slugify(post.data.category) === slugify(category)
        );
        return {
            params: { category: slugify(category) },
            props: { name: category, posts: catPosts },
        };
    });
}

const { category } = Astro.params;
const { name, posts: catPosts } = Astro.props;

const pageTitle = `${name} | Café & TV`;
const pageDescription = `${catPosts.length} post${catPosts.length !== 1 ? 's' : ''} sobre ${name} no Café & TV.`;
---

<MainLayout title={pageTitle} description={pageDescription}>
    <section class="container" aria-label={`Posts sobre ${name}`}>
        <h1 class="h1">
            Posts sobre <span>{name}</span>
        </h1>
        <div class="post-container">
            {
                catPosts.map((post) => (
                    <PostCard
                        frontmatter={post.data}
                        url={`/blog/${post.id}/`}
                        tagType="h2"
                    />
                ))
            }
        </div>
    </section>
</MainLayout>
