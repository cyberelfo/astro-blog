---
import { getCollection, render } from "astro:content";
import EditorialPostLayout from "../../layouts/EditorialPostLayout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    const publishedPosts = posts.filter((post) => !import.meta.env.PROD || !post.data.draft);
    return publishedPosts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const Layout = EditorialPostLayout;
---

<Layout frontmatter={post.data}>
    <Content />
</Layout>
